# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://megaup:megaup@localhost:5432/megaup
# Dev local: sqlite:///./megaup.db

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-um-valor-aleatorio-longo-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── IA — Anthropic / Claude ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Scheduler (progressão + lembretes) ────────────────────────────────────────
# true = habilita APScheduler (progressão IA, lembretes pagamento, lembretes streak)
ENABLE_SCHEDULER=false

# ── E-mail via Resend (https://resend.com) ────────────────────────────────────
# A aplicação usa a API HTTP do Resend diretamente (sem SDK)
# Alternativa: SMTP abaixo
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@megaup.app

# ── SMTP (alternativa ao Resend) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=sua-app-password

# ── URLs base ─────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173
# Usado em links de e-mail, redirects do Stripe e perfis públicos
APP_URL=https://megaup.onrender.com

# ── Asaas (gateway de pagamento brasileiro) ───────────────────────────────────
# Obtenha em: https://www.asaas.com/
ASAAS_API_KEY=
# true = sandbox (homologação), false = produção
ASAAS_SANDBOX=true

# ── Stripe (billing SaaS da plataforma MegaUp) ───────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obtenha em: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs dos preços criados no painel do Stripe
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# ── Web Push Notifications (VAPID) ───────────────────────────────────────────
# Gere com: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
# Ou via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
